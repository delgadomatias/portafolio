---
import LinksNav from "@components/shared/LinksNav.astro";
import Paragraph from "@components/text/Paragraph.astro";
import Subtitle from "@components/text/Subtitle.astro";
import Title from "@components/text/Title.astro";
import CircleProfileImage from "@components/ui/CircleProfileImage.astro";
import SocialLinks from "@components/ui/SocialLinks.astro";
---

<section
  class="top-0 flex flex-col justify-between gap-6 px-6 py-8 xl:py-12 2xl:py-24 lg:sticky lg:h-screen"
>
  <div class="grid gap-6 lg:gap-12">
    <div>
      <Title>Matias Delgado</Title>
      <Subtitle>Frontend Developer</Subtitle>
    </div>

    <Paragraph class="max-w-full text-start md:max-w-fit">
      Soy un desarrollador con mas afinidad en el Frontend pero con
      conocimientos en el area del Backend. Me gusta aprender cosas nuevas y
      compartir conocimientos. Desarrollo proyectos de manera Freelancer a
      traves de <a
        href="https://www.teclearla.com.ar"
        target="_blank"
        class="text-white underline">Teclearla.</a
      >
    </Paragraph>

    <LinksNav />
  </div>

  <footer class="inline-flex items-center gap-4 lg:gap-8">
    <CircleProfileImage width={50} height={50} />
    <SocialLinks />
  </footer>
</section>
